# Fridge Manager — Environment Configuration
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Get your token from @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Your personal Telegram chat/user ID
# Visit https://api.telegram.org/bot<TOKEN>/getUpdates after messaging your bot
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Evening reminder time (24h format)
EVENING_HOUR=20
EVENING_MINUTE=0

# ── Ollama (local AI vision) ───────────────────────────────────────────────────
# Default: http://localhost:11434 — change only if running Ollama on a different host
OLLAMA_URL=http://localhost:11434
OLLAMA_VISION_MODEL=llava

# ── Flask ─────────────────────────────────────────────────────────────────────
# Set to 'false' in production!
FLASK_DEBUG=true
FLASK_PORT=5000
